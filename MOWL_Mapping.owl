<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:skos="http://www.w3.org/2004/02/skos/core#"
         xmlns:mowl="http://www.semanticweb.org/mowl#"
         xmlns:iiith="http://www.semanticweb.org/mowl#"
         xmlns:iiitb="http://www.iiitb.ac.in/ontology/IIITB#"
         xmlns:iiitd="http://www.iiitd.ac.in/ontology/IIITD#"
         xml:base="http://www.semanticweb.org/mowl/mapping">

  <!-- ════════════════════════════════════════════════════════════════════════
       MAPPING ONTOLOGY DECLARATION
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Ontology rdf:about="http://www.semanticweb.org/mowl/mapping">
    <rdfs:label xml:lang="en">MOWL Integration Mapping Ontology</rdfs:label>
    <rdfs:comment xml:lang="en">This ontology defines the mappings from IIIT Hyderabad (h_ prefix), IIIT Bangalore (B_ prefix), and IIIT Delhi (D_ prefix) source ontologies to the Master OWL (MOWL) schema. Each source class, data property, and object property is mapped to its MOWL equivalent using owl:equivalentClass, owl:equivalentProperty, and rdfs:subClassOf relationships.</rdfs:comment>
    <owl:versionInfo>1.0</owl:versionInfo>
    <owl:imports rdf:resource="http://www.semanticweb.org/mowl"/>
    <owl:imports rdf:resource="http://www.semanticweb.org/mowl#"/>
    <owl:imports rdf:resource="http://www.iiitb.ac.in/ontology/IIITB"/>
    <owl:imports rdf:resource="http://www.iiitd.ac.in/ontology/IIITD"/>
    <owl:imports rdf:resource="http://www.iiith.ac.in/ontology/IIITH"/>
  </owl:Ontology>

  <!-- ╔══════════════════════════════════════════════════════════════════════╗
       ║                                                                      ║
       ║            SECTION 1: CLASS MAPPINGS                                  ║
       ║                                                                      ║
       ╚══════════════════════════════════════════════════════════════════════╝ -->

  <!-- ────────────────────────────────────────────────────────────────────────
       1.1  IIIT HYDERABAD (h_ prefix) → MOWL Class Mappings
       Source namespace: http://www.semanticweb.org/mowl#
       ──────────────────────────────────────────────────────────────────────── -->

  <!-- h_Institution → Institution -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Institution">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
  </owl:Class>

  <!-- h_Department → Department -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Department">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Department"/>
  </owl:Class>

  <!-- h_Faculty → Faculty -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Faculty">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
  </owl:Class>

  <!-- h_Course → Course -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Course">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Course"/>
  </owl:Class>

  <!-- h_Program → Program -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Program">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Program"/>
  </owl:Class>

  <!-- h_ResearchCentre → ResearchCentre -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_ResearchCentre">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#ResearchCentre"/>
  </owl:Class>

  <!-- h_Event → Event -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Event">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Event"/>
  </owl:Class>

  <!-- h_Facility → Facility -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Facility">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <!-- h_Placement → Placement -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Placement">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Placement"/>
  </owl:Class>

  <!-- h_Recruiter → Recruiter -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Recruiter">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Recruiter"/>
  </owl:Class>

  <!-- h_Award → Award -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Award">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Award"/>
  </owl:Class>

  <!-- h_Accreditation → Accreditation -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Accreditation">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Accreditation"/>
  </owl:Class>

  <!-- h_Publication → Publication -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_Publication">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#Publication"/>
  </owl:Class>

  <!-- h_ResearchLab → ResearchLab -->
  <owl:Class rdf:about="http://www.semanticweb.org/mowl#h_ResearchLab">
    <owl:equivalentClass rdf:resource="http://www.semanticweb.org/mowl#ResearchLab"/>
  </owl:Class>

