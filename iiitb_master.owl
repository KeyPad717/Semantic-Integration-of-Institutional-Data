    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasVision">
    <rdfs:label xml:lang="en">B_hasVision</rdfs:label>
    <rdfs:comment xml:lang="en">Vision statement of the university.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasResearchAreas">
    <rdfs:label xml:lang="en">B_hasResearchAreas</rdfs:label>
    <rdfs:comment xml:lang="en">Research areas of the department.</rdfs:comment>
    <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Department"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_ResearchLab"/></owl:unionOf></owl:Class></rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasDesignation">
    <rdfs:label xml:lang="en">B_hasDesignation</rdfs:label>
    <rdfs:comment xml:lang="en">Job designation of the faculty.</rdfs:comment>
