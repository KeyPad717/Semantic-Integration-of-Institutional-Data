<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
  xmlns:rdf  ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs ="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl  ="http://www.w3.org/2002/07/owl#"
  xmlns:xsd  ="http://www.w3.org/1999/XMLSchema#"
  xmlns:dc   ="http://purl.org/dc/elements/1.1/"
  xmlns:foaf ="http://xmlns.com/foaf/0.1/"
  xmlns:B    ="http://www.iiitb.ac.in/ontology/IIITB#"
  xml:base   ="http://www.iiitb.ac.in/ontology/IIITB#">

  <!-- ════════════ ONTOLOGY HEADER ════════════ -->
  <owl:Ontology rdf:about="http://www.iiitb.ac.in/ontology/IIITB#">
    <dc:title>IIITB University Ontology</dc:title>
    <dc:description>Comprehensive OWL ontology for IIITB covering faculty, programs, departments, research labs, placements, industry partners and facilities. All entities prefixed B_ for Master OWL mapping.</dc:description>
    <dc:creator>IIITB HTML Parser v1.0 — RDF/XML Edition</dc:creator>
    <dc:date>2025</dc:date>
    <owl:versionInfo>1.0.0</owl:versionInfo>
  </owl:Ontology>

  <!-- ════════════════════════════════════════
       OWL CLASSES  (prefix B_)
  ════════════════════════════════════════ -->
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_University">
    <rdfs:label xml:lang="en">B_University</rdfs:label>
    <rdfs:comment xml:lang="en">A university or academic institution.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Department">
    <rdfs:label xml:lang="en">B_Department</rdfs:label>
    <rdfs:comment xml:lang="en">An academic department within the university.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Faculty">
    <rdfs:label xml:lang="en">B_FacultyMember</rdfs:label>
    <rdfs:comment xml:lang="en">A faculty member of IIITB.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Program">
    <rdfs:label xml:lang="en">B_Program</rdfs:label>
    <rdfs:comment xml:lang="en">An academic program offered by a department.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_UGProgram">
    <rdfs:label xml:lang="en">B_UGProgram</rdfs:label>
    <rdfs:comment xml:lang="en">An undergraduate level academic program.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_Program"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_PGProgram">
    <rdfs:label xml:lang="en">B_PGProgram</rdfs:label>
    <rdfs:comment xml:lang="en">A postgraduate level academic program.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_Program"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_DoctoralProgram">
    <rdfs:label xml:lang="en">B_DoctoralProgram</rdfs:label>
    <rdfs:comment xml:lang="en">A doctoral Ph.D research program.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_Program"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Course">
    <rdfs:label xml:lang="en">B_Course</rdfs:label>
    <rdfs:comment xml:lang="en">An individual course or subject.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_ResearchLab">
    <rdfs:label xml:lang="en">B_ResearchLab</rdfs:label>
    <rdfs:comment xml:lang="en">A research laboratory or group.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Publication">
    <rdfs:label xml:lang="en">B_Publication</rdfs:label>
    <rdfs:comment xml:lang="en">A research paper or publication by faculty.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Placement">
    <rdfs:label xml:lang="en">B_Placement</rdfs:label>
    <rdfs:comment xml:lang="en">Annual placement record of the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Recruiter">
    <rdfs:label xml:lang="en">B_Recruiter</rdfs:label>
    <rdfs:comment xml:lang="en">A company that recruits from the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Accreditation">
    <rdfs:label xml:lang="en">B_Accreditation</rdfs:label>
    <rdfs:comment xml:lang="en">An accreditation or ranking body result.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Facility">
    <rdfs:label xml:lang="en">B_Facility</rdfs:label>
    <rdfs:comment xml:lang="en">A campus facility available to students.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_IndustryPartner">
    <rdfs:label xml:lang="en">B_IndustryPartner</rdfs:label>
    <rdfs:comment xml:lang="en">An industry partner of the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Student">
    <rdfs:label xml:lang="en">B_Student</rdfs:label>
    <rdfs:comment xml:lang="en">A student enrolled at the university.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Award">
    <rdfs:label xml:lang="en">B_Award</rdfs:label>
    <rdfs:comment xml:lang="en">An award or recognition received.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_ResearchProject">
    <rdfs:label xml:lang="en">B_ResearchProject</rdfs:label>
    <rdfs:comment xml:lang="en">A funded research project at the university.</rdfs:comment>
    
  </owl:Class>

  <!-- ════════════════════════════════════════
       DATA PROPERTIES  (prefix B_)
  ════════════════════════════════════════ -->
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasName">
    <rdfs:label xml:lang="en">B_hasName</rdfs:label>
    <rdfs:comment xml:lang="en">Full name of the entity.</rdfs:comment>
    <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_University"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Department"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Faculty"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Program"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Course"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_ResearchLab"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Recruiter"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Facility"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_IndustryPartner"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Student"/></owl:unionOf></owl:Class></rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasShortName">
    <rdfs:label xml:lang="en">B_hasShortName</rdfs:label>
    <rdfs:comment xml:lang="en">Abbreviation or short name.</rdfs:comment>
    <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_University"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Department"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Program"/></owl:unionOf></owl:Class></rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasEstablishedYear">
    <rdfs:label xml:lang="en">B_hasEstablishedYear</rdfs:label>
    <rdfs:comment xml:lang="en">Year the university was established.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasUniversityType">
    <rdfs:label xml:lang="en">B_hasUniversityType</rdfs:label>
    <rdfs:comment xml:lang="en">Type of university such as Deemed, Central.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasLocation">
    <rdfs:label xml:lang="en">B_hasLocation</rdfs:label>
    <rdfs:comment xml:lang="en">Physical address.</rdfs:comment>
    <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_University"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Facility"/></owl:unionOf></owl:Class></rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasWebsite">
    <rdfs:label xml:lang="en">B_hasWebsite</rdfs:label>
    <rdfs:comment xml:lang="en">Official website URL.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasEmail">
    <rdfs:label xml:lang="en">B_hasEmail</rdfs:label>
    <rdfs:comment xml:lang="en">Official email address.</rdfs:comment>
    <rdfs:domain><owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_University"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Faculty"/><rdf:Description rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_Department"/></owl:unionOf></owl:Class></rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasPhone">
    <rdfs:label xml:lang="en">B_hasPhone</rdfs:label>
    <rdfs:comment xml:lang="en">Contact phone number.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasTotalStudents">
    <rdfs:label xml:lang="en">B_hasTotalStudents</rdfs:label>
    <rdfs:comment xml:lang="en">Total number of enrolled students.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasTotalFaculty">
    <rdfs:label xml:lang="en">B_hasTotalFaculty</rdfs:label>
    <rdfs:comment xml:lang="en">Total number of faculty members.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasCampusArea">
    <rdfs:label xml:lang="en">B_hasCampusArea</rdfs:label>
