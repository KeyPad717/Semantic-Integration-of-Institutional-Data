    <rdfs:domain rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#B_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitb.ac.in/ontology/IIITB#B_hasNAACGrade">
    <rdfs:label xml:lang="en">B_hasNAACGrade</rdfs:label>
